  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id,\n            user_id,\n            code,\n            type as \"invite_type\",\n            expires_at,\n            use_count,\n            revoked,\n            created_at\n        FROM user_invite_links\n        WHERE code = $1\n          AND NOT revoked\n          AND (expires_at IS NULL OR expires_at > NOW())\n        FOR UPDATE\n        ",
