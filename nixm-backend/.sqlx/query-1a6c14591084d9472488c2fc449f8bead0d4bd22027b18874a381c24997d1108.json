{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            m.message_uuid,\n            m.from_user_id,\n            m.timestamp,\n            mp.iv,\n            mp.ciphertext,\n            mp.id as payload_id\n        FROM message_payloads mp\n        JOIN messages m ON m.id = mp.message_id\n        WHERE mp.device_id = $1 AND mp.delivered = FALSE\n        ORDER BY m.timestamp ASC\n        ",
